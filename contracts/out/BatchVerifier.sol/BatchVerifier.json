"},{\"inputs\":[{\"internalType\":\"bytes32[]\",\"name\":\"leaves\",\"type\":\"bytes32[]\"},{\"internalType\":\"uint256[]\",\"name\":\"indices\",\"type\":\"uint256[]\"},{\"internalType\":\"bytes32[][]\",\"name\":\"allSiblings\",\"type\":\"bytes32[][]\"},{\"internalType\":\"bytes32\",\"name\":\"expectedRoot\",\"type\":\"bytes32\"}],\"name\":\"verifyBatchDetailed\",\"outputs\":[{\"internalType\":\"bool[]\",\"name\":\"results\",\"type\":\"bool[]\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"components\":[{\"internalType\":\"bytes32\",\"name\":\"traceCommitment\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32\",\"name\":\"constraintCommitment\",\"type\":\"bytes32\"},{\"internalType\":\"bytes32[]\",\"name\":\"friCommitments\",\"type\":\"bytes32[]\"},{\"internalType\":\"uint256[]\",\"name\":\"friChallenges\",\"type\":\"uint256[]\"},{\"internalType\":\"uint256[]\",\"name\":\"queryIndices\",\"type\":\"uint256[]\"},{\"internalType\":\"bytes32[][]\",\"name\":\"merkleProofs\",\"type\":\"bytes32[][]\"},{\"internalType\":\"uint256[][]\",\"name\":\"evaluations\",\"type\":\"uint256[][]\"},{\"internalType\":\"uint256[]\",\"name\":\"finalPolynomial\",\"type\":\"uint256[]\"}],\"internalType\":\"struct ProofCodec.STARKProof[]\",\"name\":\"proofs\",\"type\":\"tuple[]\"},{\"internalType\":\"bytes32[]\",\"name\":\"publicInputs\",\"type\":\"bytes32[]\"}],\"name\":\"verifySTARKBatch\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"validCount\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"author\":\"Quantum Shield Team\",\"custom:security-contact\":\"security@quantumshield.io\",\"custom:version\":\"0.1.0\",\"details\":\"IMPL-009: Implements batch proof verification for gas efficiency  ## Overview This contract provides batch verification of STARK proofs, optimizing gas costs by sharing Merkle path computations across multiple proofs.  ## Gas Optimization Strategy 1. **Shared Merkle Paths**: Proofs sharing ancestors reuse hash computations 2. **Batch Processing**: Amortize fixed costs across multiple proofs 3. **Early Exit**: Skip invalid proofs quickly  ## Target Performance - 10-proof batch: \\u226540% gas reduction vs individual verification - 20-proof batch: \\u226550% gas reduction vs individual verification  ## CP-1 Compliance (Quantum Resistance) - Uses ONLY SHA3-256 (FIPS 202) for all hash operations - keccak256 is PROHIBITED - 128-bit security level maintained \",\"kind\":\"dev\",\"methods\":{\"constructor\":{\"params\":{\"_sharedMerkle\":\"Address of SharedMerkle contract\"}},\"estimateBatchGas(uint256,uint256)\":{\"details\":\"Useful for gas optimization analysis\",\"params\":{\"batchSize\":\"Number of proofs in batch\",\"proofDepth\":\"Depth of Merkle proofs\"},\"returns\":{\"estimatedGas\":\"Estimated gas cost\"}},\"isOptimalBatchSize(uint256)\":{\"params\":{\"batchSize\":\"Proposed batch size\"},\"returns\":{\"optimal\":\"True if batch size is in optimal range\"}},\"verifyBatch(bytes32[],uint256[],bytes32[][],bytes32)\":{\"details\":\"Main entry point for batch verification\",\"params\":{\"allSiblings\":\"2D array of sibling hashes (Merkle proof paths)\",\"expectedRoot\":\"Expected Merkle root\",\"indices\":\"Array of leaf positions in the tree\",\"leaves\":\"Array of leaf values to verify\"},\"returns\":{\"validCount\":\"Number of valid proofs in the batch\"}},\"verifyBatchDetailed(bytes32[],uint256[],bytes32[][],bytes32)\":{\"details\":\"Returns validity status for each proof\",\"params\":{\"allSiblings\":\"2D array of sibling hashes\",\"expectedRoot\":\"Expected Merkle root\",\"indices\":\"Array of leaf positions\",\"leaves\":\"Array of leaf values\"},\"returns\":{\"results\":\"Array of validity flags for each proof\"}},\"verifySTARKBatch((bytes32,bytes32,bytes32[],uint256[],uint256[],bytes32[][],uint256[][],uint256[])[],bytes32[])\":{\"details\":\"Verifies trace commitments for multiple STARK proofs\",\"params\":{\"proofs\":\"Array of STARK proofs to verify\",\"publicInputs\":\"Array of public inputs\"},\"returns\":{\"validCount\":\"Number of valid proofs\"}}},\"title\":\"BatchVerifier\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"MAX_BATCH_SIZE()\":{\"notice\":\"Maximum batch size to prevent DoS\"},\"MIN_BATCH_SIZE()\":{\"notice\":\"Minimum batch size for optimization benefit\"},\"constructor\":{\"notice\":\"Deploy BatchVerifier with SharedMerkle dependency\"},\"estimateBatchGas(uint256,uint256)\":{\"notice\":\"Estimate gas for batch verification\"},\"getSharedMerkleAddress()\":{\"notice\":\"Get SharedMerkle address\"},\"getVersion()\":{\"notice\":\"Get contract version\"},\"isOptimalBatchSize(uint256)\":{\"notice\":\"Check if batch size is optimal\"},\"sharedMerkle()\":{\"notice\":\"SharedMerkle library for path optimization\"},\"verifyBatch(bytes32[],uint256[],bytes32[][],bytes32)\":{\"notice\":\"Verify a batch of Merkle proofs\"},\"verifyBatchDetailed(bytes32[],uint256[],bytes32[][],bytes32)\":{\"notice\":\"Verify batch with detailed results\"},\"verifySTARKBatch((bytes32,bytes32,bytes32[],uint256[],uint256[],bytes32[][],uint256[][],uint256[])[],bytes32[])\":{\"notice\":\"Verify batch of STARK proofs\"}},\"notice\":\"Batch verification for STARK proofs with gas optimization\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/BatchVerifier.sol\":\"BatchVerifier\"},\"evmVersion\":\"paris\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":@openzeppelin/=lib/openzeppelin-contracts/\",\":erc4626-tests/=lib/openzeppelin-contracts/lib/erc4626-tests/\",\":forge-std/=lib/forge-std/src/\",\":halmos-cheatcodes/=lib/openzeppelin-contracts/lib/halmos-cheatcodes/src/\",\":lib/openzeppelin-contracts/=lib/openzeppelin-contracts/\",\":openzeppelin-contracts/=lib/openzeppelin-contracts/\"],\"viaIR\":true},\"sources\":{\"src/BatchVerifier.sol\":{\"keccak256\":\"0x331cf822f19facdd2c112aa028aac74acb7294ce579fb00f7d82670ca3440883\",\"l