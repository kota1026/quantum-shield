# =============================================================================
# Quantum Shield - Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and fill in your values
# NEVER commit the actual .env.production file!
#
# Security: Use Docker secrets or a secrets manager for sensitive values
# in production deployments.
# =============================================================================

# =============================================================================
# REQUIRED: Blockchain Configuration
# =============================================================================

# L1 Ethereum RPC URL (Mainnet or Sepolia)
L1_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# L1 WebSocket URL for event subscriptions
L1_WS_URL=wss://mainnet.infura.io/ws/v3/YOUR_PROJECT_ID

# =============================================================================
# REQUIRED: Contract Addresses
# =============================================================================

# L1 Vault Contract Address
L1_VAULT_ADDRESS=0x...

# EditionConfig Contract Address
EDITION_CONFIG_ADDRESS=0x...

# ProverRegistry Contract Address
PROVER_REGISTRY_ADDRESS=0x...

# STARK Verifier Contract Address
STARK_VERIFIER_ADDRESS=0x...

# =============================================================================
# REQUIRED: Chainlink VRF Configuration
# =============================================================================

# VRF Coordinator Address
# Mainnet: 0x271682DEB8C4E0901D1a1550aD2e64D568E69909
# Sepolia: 0x8103B0A8A00be2DDC778e6e7eaa21791Cd364625
CHAINLINK_VRF_COORDINATOR=0x271682DEB8C4E0901D1a1550aD2e64D568E69909

# VRF Key Hash
CHAINLINK_VRF_KEY_HASH=0x8af398995b04c28e9951adb9721ef74c74f93e6a478f39e7e0777be13527e7ef

# VRF Subscription ID
CHAINLINK_VRF_SUBSCRIPTION_ID=

# =============================================================================
# REQUIRED: Database Configuration
# =============================================================================

# PostgreSQL Configuration
POSTGRES_USER=quantum_shield
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=quantum_shield_production
POSTGRES_PORT=5432

# =============================================================================
# REQUIRED: Redis Configuration
# =============================================================================

REDIS_PORT=6379

# =============================================================================
# REQUIRED: RabbitMQ Configuration
# =============================================================================

RABBITMQ_USER=quantum_shield
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# =============================================================================
# REQUIRED: Security Configuration
# =============================================================================

# JWT Secret Key (generate with: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET

# =============================================================================
# Service Ports
# =============================================================================

API_PORT=8080
EVENT_BRIDGE_PORT=8081
WEBSOCKET_PORT=8082
STARK_PROVER_PORT=3000

# =============================================================================
# Monitoring Configuration
# =============================================================================

PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ALERTMANAGER_PORT=9093

# Grafana Admin Credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GRAFANA_ROOT_URL=https://monitoring.yourdomain.com

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: error, warn, info, debug, trace
RUST_LOG=info

# =============================================================================
# Alerting Configuration (Optional)
# =============================================================================

# Slack/Discord webhook for alerts
ALERT_WEBHOOK_URL=

# =============================================================================
# Performance Tuning
# =============================================================================

# Event polling interval in milliseconds
POLLING_INTERVAL_MS=5000

# Monitor bot check interval in milliseconds
MONITORING_INTERVAL_MS=60000

# STARK prover thread count
PROVER_THREADS=4

# =============================================================================
# TLS Configuration (Production)
# =============================================================================

# Path to TLS certificate and key (for HTTPS)
TLS_CERT_PATH=/etc/ssl/certs/quantum-shield.crt
TLS_KEY_PATH=/etc/ssl/private/quantum-shield.key

# =============================================================================
# Backup Configuration
# =============================================================================

# S3 bucket for backups (optional)
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=us-east-1

# =============================================================================
# Rate Limiting
# =============================================================================

# API rate limit (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=100

# =============================================================================
# Enterprise Configuration (Optional)
# =============================================================================

# Enterprise license key
ENTERPRISE_LICENSE_KEY=

# Custom branding
CUSTOM_LOGO_URL=
CUSTOM_THEME=default
