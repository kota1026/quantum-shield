{
  "name": "@quantum-shield/react",
  "version": "0.1.0",
  "description": "React Hooks for Quantum Shield SDK",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^18.2.45",
    "react": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.3",
    "@testing-library/react": "^14.1.2",
    "jsdom": "^23.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "keywords": [
    "quantum",
    "cryptography",
    "dilithium",
    "react",
    "hooks",
    "post-quantum"
  ],
  "author": "Quantum Shield Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kota1026/quantum-shield.git",
    "directory": "packages/sdk/react"
  }
}
