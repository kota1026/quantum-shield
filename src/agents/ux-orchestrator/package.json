{
  "name": "quantum-shield-ux-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "11-role autonomous UX/visual/copy/a11y/perf verification framework with verify→fix→verify loop",
  "type": "module",
  "engines": { "node": ">=20" },
  "bin": {
    "qs-ux": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "verify": "tsx src/index.ts",
    "verify:home": "tsx src/index.ts --route home-ja",
    "verify:all": "tsx src/index.ts --route all",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "kleur": "^4.1.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
