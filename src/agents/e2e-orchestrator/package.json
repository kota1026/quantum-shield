{
  "name": "quantum-shield-e2e-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Spec-driven 11-agent autonomous E2E verification framework for Quantum Shield",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "qs-e2e": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "verify": "tsx src/index.ts",
    "verify:lock": "tsx src/index.ts --sequence lock",
    "verify:all": "tsx src/index.ts --sequence all",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "kleur": "^4.1.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
