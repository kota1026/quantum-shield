# AI Prover Agent Configuration

# Prover ID (登録済みのProver ID)
PROVER_ID=0xAI_PROVER_AGENT_001_7b3f8e2a1c9d4f5e6a0b8c7d9e1f2a3b4c5d6e7f

# Backend API
API_URL=http://localhost:8080
API_TIMEOUT=30

# Polling
POLLING_INTERVAL=10
MAX_BATCH_SIZE=10

# Confidence Thresholds
AUTO_SIGN_THRESHOLD=0.99
ESCALATE_THRESHOLD=0.80

# HSM (開発環境では localhost でローカル署名)
HSM_ENDPOINT=http://localhost:8888
HSM_TIMEOUT=30

# AI Model
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1024

# Anthropic API Key (必須)
ANTHROPIC_API_KEY=your-api-key-here

# Escalation (オプション)
SLACK_WEBHOOK=
ESCALATION_EMAIL=

# Logging
LOG_LEVEL=info
AUDIT_LOG_FILE=./logs/ai-prover.log
AUDIT_RETENTION_DAYS=90
