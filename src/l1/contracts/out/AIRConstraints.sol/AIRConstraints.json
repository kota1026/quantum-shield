,\"type\":\"uint256\"}],\"internalType\":\"struct AIRConstraints.BoundaryConstraint[]\",\"name\":\"boundaryConstraints\",\"type\":\"tuple[]\"}],\"name\":\"verifyAIR\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"valid\",\"type\":\"bool\"}],\"stateMutability\":\"pure\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"actualValue\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"expectedValue\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"index\",\"type\":\"uint256\"}],\"name\":\"verifyBoundaryConstraint\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"valid\",\"type\":\"bool\"}],\"stateMutability\":\"pure\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256[]\",\"name\":\"trace\",\"type\":\"uint256[]\"},{\"components\":[{\"internalType\":\"uint256\",\"name\":\"index\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"expectedValue\",\"type\":\"uint256\"}],\"internalType\":\"struct AIRConstraints.BoundaryConstraint[]\",\"name\":\"constraints\",\"type\":\"tuple[]\"}],\"name\":\"verifyBoundaryConstraints\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"valid\",\"type\":\"bool\"}],\"stateMutability\":\"pure\",\"type\":\"function\"}],\"devdoc\":{\"author\":\"Quantum Shield Team\",\"custom:security-contact\":\"security@quantumshield.io\",\"custom:version\":\"0.1.0\",\"details\":\"Implements constraint system for STARK proofs  ## Overview AIR constraints define the rules that a valid execution trace must satisfy. They consist of: - Boundary constraints: conditions at specific trace positions - Transition constraints: rules between consecutive trace elements  ## CP-1 Compliance (Quantum Resistance) - Uses SHA3-256 for all hash operations (domain separation) - Goldilocks field (2^64 - 2^32 + 1) for all arithmetic - 128-bit security level \",\"kind\":\"dev\",\"methods\":{\"computeBoundaryZerofier(uint256,uint256,uint256)\":{\"details\":\"For boundary constraint at index i: (x - \\u03c9^i) divides C(x)\",\"params\":{\"boundaryIndex\":\"Index of boundary constraint\",\"omega\":\"Domain generator (root of unity)\",\"x\":\"Evaluation point\"},\"returns\":{\"zerofier\":\"The zerofier polynomial value at x\"}},\"computeDomainGenerator(uint256)\":{\"params\":{\"domainSize\":\"Size of the domain (must be power of 2)\"},\"returns\":{\"omega\":\"The domain generator (root of unity)\"}},\"computeTransitionZerofier(uint256,uint256,uint256)\":{\"details\":\"For transition constraints, zerofier is: (x^n - 1) / (x - \\u03c9^(n-1))\",\"params\":{\"omega\":\"Domain generator\",\"traceLength\":\"Length of trace (domain size)\",\"x\":\"Evaluation point\"},\"returns\":{\"zerofier\":\"The zerofier polynomial value at x\"}},\"evaluateAllTransitionConstraints(uint256[])\":{\"details\":\"Uses doubling constraint: trace[i+1] = 2 * trace[i]\",\"params\":{\"trace\":\"The execution trace\"},\"returns\":{\"valid\":\"True if all transitions are valid\"}},\"evaluateDoublingConstraint(uint256,uint256)\":{\"details\":\"Constraint: next = 2 * current (returns 0 if satisfied)\",\"params\":{\"current\":\"Current trace value\",\"next\":\"Next trace value\"},\"returns\":{\"constraintValue\":\"0 if satisfied, non-zero otherwise\"}},\"evaluateFibonacciConstraint(uint256,uint256,uint256)\":{\"details\":\"Constraint: next2 = next1 + current (returns 0 if satisfied)\",\"params\":{\"current\":\"Current value (trace[i])\",\"next1\":\"Next value (trace[i+1])\",\"next2\":\"Value after next (trace[i+2])\"},\"returns\":{\"constraintValue\":\"0 if satisfied, non-zero otherwise\"}},\"evaluatePolynomialConstraint(uint256,uint256)\":{\"details\":\"Constraint: (next - 2*current) * (next - current - 1) = 0 This allows either doubling OR incrementing by 1\",\"params\":{\"current\":\"Current trace value\",\"next\":\"Next trace value\"},\"returns\":{\"valid\":\"True if constraint is satisfied\"}},\"getVersion()\":{\"returns\":{\"name\":\"Contract name\",\"version\":\"Version string\"}},\"maxCons