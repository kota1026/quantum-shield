{
  "name": "@quantum-shield/sdk",
  "version": "0.1.0",
  "description": "Quantum Shield TypeScript SDK - Post-quantum secure bridge client",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ethers": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.3"
  },
  "keywords": [
    "quantum",
    "cryptography",
    "dilithium",
    "ethereum",
    "bridge",
    "post-quantum"
  ],
  "author": "Quantum Shield Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kota1026/quantum-shield.git",
    "directory": "packages/sdk/typescript"
  }
}
