# Quantum Shield - Sepolia Testnet Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file!

# =============================================================================
# REQUIRED: RPC Provider
# =============================================================================
# Get your RPC URL from Alchemy, Infura, or another provider
# Alchemy: https://dashboard.alchemy.com/
# Infura: https://app.infura.io/

SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# =============================================================================
# REQUIRED: Deployer Account
# =============================================================================
# The private key of the account that will deploy contracts
# This account needs Sepolia ETH for gas
# Get Sepolia ETH from: https://sepoliafaucet.com/

DEPLOYER_PRIVATE_KEY=your_private_key_here

# =============================================================================
# OPTIONAL: Etherscan Verification
# =============================================================================
# Get your API key from: https://etherscan.io/myapikey

ETHERSCAN_API_KEY=your_etherscan_api_key

# =============================================================================
# OPTIONAL: Additional Configuration
# =============================================================================

# Gas price in gwei (leave empty for automatic)
GAS_PRICE_GWEI=

# Gas limit override
GAS_LIMIT=

# Deployment confirmation count (default: 2)
CONFIRMATIONS=2

# =============================================================================
# CHAINLINK VRF (for production)
# =============================================================================
# Sepolia VRF Coordinator: 0x8103B0A8A00be2DDC778e6e7eaa21791Cd364625
# LINK Token: 0x779877A7B0D9E8603169DdbD7836e478b4624789

VRF_COORDINATOR=0x8103B0A8A00be2DDC778e6e7eaa21791Cd364625
VRF_SUBSCRIPTION_ID=
VRF_KEY_HASH=0x474e34a077df58807dbe9c96d3c009b23b3c6d0cce433e59bbf5b34f823bc56c
