# Quantum Shield API - Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgres://quantum:quantum_dev@localhost:5432/quantum_shield

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=  # Optional: Set if Redis requires authentication

# ===========================================
# RabbitMQ Configuration
# ===========================================
RABBITMQ_URL=amqp://quantum:quantum_dev@localhost:5672

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-secure-jwt-secret-change-in-production

# ===========================================
# L3 Configuration (Aegis Chain)
# ===========================================
# Local Anvil node (docker-compose up l3-node)
L3_ENDPOINT=http://localhost:8545
L3_CHAIN_ID=31337

# ===========================================
# L1 Configuration (Sepolia)
# ===========================================
# Use Infura, Alchemy, or local node
L1_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
L1_CHAIN_ID=11155111

# Contract addresses (set after deployment)
# BRIDGE_VERIFIER_ADDRESS=0x...
# TREASURY_VAULT_ADDRESS=0x...

# ===========================================
# VRF Configuration (Chainlink)
# ===========================================
VRF_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VRF_RPC_URL=http://localhost:8545

# ===========================================
# Server Configuration
# ===========================================
HOST=0.0.0.0
PORT=8080
RUST_LOG=info,quantum_shield_api=debug

# ===========================================
# Security Configuration
# ===========================================
# Normal time lock (hours)
NORMAL_TIME_LOCK_HOURS=24
# Emergency time lock (days)
EMERGENCY_TIME_LOCK_DAYS=7
# Emergency timeout (hours) - triggers emergency path
EMERGENCY_TIMEOUT_HOURS=72
# Maximum pause duration (hours)
MAX_PAUSE_DURATION_HOURS=72
