+#[derive(Debug)]
+pub enum LockError {
+    InvalidSignature,
+    MalformedKey,
+    MalformedSignature,
+    Internal(String),
+}
+
+impl axum::response::IntoResponse for LockError {
+    fn into_response(self) -> axum::response::Response {
+        let (status, msg) = match self {
+            LockError::InvalidSignature => (
+                StatusCode::UNAUTHORIZED,
+                "invalid dilithium signature",
+            ),
+            LockError::MalformedKey => (
+                StatusCode::BAD_REQUEST,
+                "malformed dilithium public key",
+            ),
+            LockError::MalformedSignature => (
+                StatusCode::BAD_REQUEST,
+                "malformed dilithium signature bytes",
+            ),
+            LockError::Internal(ref s) => {
+                tracing::error!(err = %s, "lock internal error");
+                (StatusCode::INTERNAL_SERVER_ERROR, "internal error")
+            }
+        };
+        (status, msg).into_response()
+    }
+}
