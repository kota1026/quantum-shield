{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "api",
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/slack",
      "dest": "/api/slack/index.py"
    },
    {
      "src": "/api/health",
      "dest": "/api/slack/index.py"
    }
  ]
}
