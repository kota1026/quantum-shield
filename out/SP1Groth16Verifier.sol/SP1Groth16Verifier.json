 key\"}},\"getVerifierType()\":{\"returns\":{\"_0\":\"\\\"groth16\\\", \\\"plonk\\\", or \\\"stark\\\"\"}},\"isQuantumResistant()\":{\"returns\":{\"_0\":\"isQuantumResistant True for STARK-based verifiers\"}},\"verifyProof(bytes,uint256[])\":{\"params\":{\"proof\":\"The encoded proof data (format depends on implementation)\",\"publicInputs\":\"The public inputs to the circuit\"},\"returns\":{\"valid\":\"True if the proof is valid\"}}},\"title\":\"SP1Groth16Verifier - Groth16 Verifier for SP1 Proofs\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"getVerificationKeyHash()\":{\"notice\":\"Get the verification key hash for this verifier\"},\"getVerifierType()\":{\"notice\":\"Get the verifier type identifier\"},\"isQuantumResistant()\":{\"notice\":\"Check if verifier supports quantum-resistant proofs\"},\"verifyProof(bytes,uint256[])\":{\"notice\":\"Verify a ZK proof of aggregated Dilithium signature verification\"},\"vkHash()\":{\"notice\":\"Verification key hash (set during deployment)\"}},\"notice\":\"Verifies Groth16 proofs generated by SP1's compression pipeline\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"contracts/verifiers/SP1Groth16Verifier.sol\":\"SP1Groth16Verifier\"},\"evmVersion\":\"shanghai\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":forge-std/=lib/forge-std/src/\"]},\"sources\":{\"contracts/interfaces/IQuantumVerifier.sol\":{\"keccak256\":\"0xc1e0c49b24d3a617e5e12e2922dc48aa57a441552e58b0f227f64a27af77824a\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://fd0ab6a23a2ea3b000fd17681864bedca55ae32011225f2d1a5ac7cf63ea9836\",\"dweb:/ipfs/QmZKBWegupVYm3uBBMXUGGUEkDqcHd69mhbcbqyJGdMCNc\"]},\"contracts/verifiers/SP1Groth16Verifier.sol\":{\"keccak256\":\"0xd0ad68d1297ae3d37814269f393d96d2af60560fc5648fe252903b2a04e22067\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://42d049096b96a86a5e2dad80d9a87ad54fd8dfd9189d1783b15d89a39f4dda97\",\"dweb:/ipfs/QmbdkthKfLnwHqP4rk3CFt