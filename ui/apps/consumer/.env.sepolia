# Quantum Shield Consumer App - Environment Variables
# Sepolia Testnet Configuration

# Network
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_NETWORK_NAME=sepolia

# L1 Contract Addresses (Sepolia Testnet - Deployed 2025-12-27)
NEXT_PUBLIC_QS_VAULT_ADDRESS=0xAdEB23203bf5C45e3CbD3406122aED067E41255D
NEXT_PUBLIC_QS_STARK_VERIFIER_ADDRESS=0x93f550917E45b6BDA45dE4fE3e0bAB09FfC38848
NEXT_PUBLIC_QS_SPHINCS_VERIFIER_ADDRESS=0xd5F3cEA1fE247fff7e15cBA00C1f804D2Bd126f3
NEXT_PUBLIC_QS_BATCH_VERIFIER_ADDRESS=0xD264ac2CB8548B76d95E9267ACADDb42CE608730
NEXT_PUBLIC_QS_AIR_CONSTRAINTS_ADDRESS=0x49a1f515A10447197078b7282e8d8C1AD658b149
NEXT_PUBLIC_QS_CONSTRAINT_EVALUATOR_ADDRESS=0x5fbffa05d45E85F052Ac9bD0DA30a7C2fb070c81
NEXT_PUBLIC_QS_SHARED_MERKLE_ADDRESS=0x956139A615687fA9e0F85e9ff520129f4C3C8574

# Token Contracts (placeholder - not yet deployed)
NEXT_PUBLIC_QS_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_QS_GOVERNANCE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_QS_TIMELOCK_ADDRESS=0x0000000000000000000000000000000000000000

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# WalletConnect Project ID
# ⚠️ REQUIRED for production wallet connections
# Get your project ID from: https://cloud.walletconnect.com/
# For local development, MetaMask injection works without this
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Etherscan URL for transparency links
NEXT_PUBLIC_ETHERSCAN_URL=https://sepolia.etherscan.io

# Feature Flags
NEXT_PUBLIC_ENABLE_TESTNET_MODE=true
NEXT_PUBLIC_ENABLE_MOCK_DATA=false

# Dilithium WASM Module (optional - uses mock signatures if not set)
# Production URL: https://cdn.quantum-shield.io/wasm/dilithium-v1.0.0.wasm
NEXT_PUBLIC_DILITHIUM_WASM_URL=
