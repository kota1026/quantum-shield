# =============================================================================
# Quantum Shield — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- API Keys (Optional for dev, required for L1 integration) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- L1 Configuration (Ethereum Sepolia) ---
QS__L1_PRIVATE_KEY=your_sepolia_private_key_hex_without_0x
QS__L1_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# --- Database ---
DATABASE_URL=postgresql://quantum:quantum_dev@localhost:5432/quantum_shield

# --- VRF (Optional — zero address = dev mode) ---
# QS__VRF__PRIVATE_KEY=your_vrf_private_key_hex
# QS__VRF__CONTRACT_ADDRESS=0x...

# --- Frontend ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- E2E Testing ---
E2E_TEST_PRIVATE_KEY=0x_your_test_wallet_private_key

# --- Production Mode (uncomment for production) ---
# RUN_MODE=production
# QS__JWT__SECRET=your_secure_random_jwt_secret_min_32_chars
# QS__RATE_LIMIT__ENABLED=true
