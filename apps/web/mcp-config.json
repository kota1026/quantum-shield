{
  "$schema": "https://raw.githubusercontent.com/anthropics/model-context-protocol/main/schema/config.json",
  "name": "quantum-shield-phase6",
  "version": "1.0.0",
  "description": "MCP configuration for Quantum Shield Phase 6 AI Agentic development",
  "servers": {
    "figma": {
      "name": "figma-mcp",
      "command": "npx",
      "args": ["@anthropic/mcp-server-figma"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}"
      },
      "description": "Figma design token extraction and component reference",
      "capabilities": {
        "tools": ["get_file", "get_styles", "get_components", "get_variables"]
      }
    },
    "filesystem": {
      "name": "filesystem-mcp",
      "command": "npx",
      "args": ["@anthropic/mcp-server-filesystem"],
      "env": {
        "ALLOWED_PATHS": "/home/user/quantum-shield"
      },
      "description": "File system operations for code generation",
      "capabilities": {
        "tools": ["read_file", "write_file", "list_directory", "search_files"]
      }
    },
    "playwright": {
      "name": "playwright-mcp",
      "command": "npx",
      "args": ["@anthropic/mcp-server-playwright"],
      "description": "Browser automation for E2E testing and visual verification",
      "capabilities": {
        "tools": ["navigate", "screenshot", "click", "type", "evaluate"]
      }
    },
    "postgres": {
      "name": "postgres-mcp",
      "command": "npx",
      "args": ["@anthropic/mcp-server-postgres"],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      },
      "description": "Database operations for API implementation",
      "capabilities": {
        "tools": ["query", "execute", "schema", "describe"]
      }
    },
    "git": {
      "name": "git-mcp",
      "command": "npx",
      "args": ["@anthropic/mcp-server-git"],
      "description": "Version control operations",
      "capabilities": {
        "tools": ["status", "commit", "push", "branch", "diff"]
      }
    }
  },
  "agents": {
    "ui_agent": {
      "name": "UI Implementation Agent",
      "prompt_file": "../../docs_new/02_agents_prompt/02_prompts/30_ui_impl.md",
      "model": "claude-sonnet-4-20250514",
      "servers": ["figma", "filesystem"],
      "description": "HTML Mock → React component conversion"
    },
    "api_agent": {
      "name": "API Implementation Agent",
      "prompt_file": "../../docs_new/02_agents_prompt/02_prompts/34_api_impl.md",
      "model": "claude-sonnet-4-20250514",
      "servers": ["postgres", "filesystem"],
      "description": "API endpoint implementation (NO MOCK DATA)"
    },
    "test_agent": {
      "name": "Test Agent",
      "prompt_file": "../../docs_new/02_agents_prompt/02_prompts/37_e2e_test.md",
      "model": "claude-sonnet-4-20250514",
      "servers": ["playwright", "filesystem"],
      "description": "E2E test generation and self-healing"
    },
    "i18n_agent": {
      "name": "i18n Audit Agent",
      "prompt_file": "../../docs_new/02_agents_prompt/02_prompts/32_i18n_audit.md",
      "model": "claude-sonnet-4-20250514",
      "servers": ["filesystem"],
      "description": "Internationalization completeness audit"
    },
    "a11y_agent": {
      "name": "Accessibility Agent",
      "prompt_file": "../../docs_new/02_agents_prompt/02_prompts/33_a11y_check.md",
      "model": "claude-sonnet-4-20250514",
      "servers": ["playwright", "filesystem"],
      "description": "WCAG 2.1 AA compliance verification"
    },
    "review_agent": {
      "name": "Design Review Agent",
      "prompt_file": "../../docs_new/02_agents_prompt/02_prompts/31_design_pir.md",
      "model": "claude-sonnet-4-20250514",
      "servers": ["filesystem"],
      "description": "Persona-based design review"
    }
  }
}
