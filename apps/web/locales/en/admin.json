      "welcome": {
        "title": "Welcome to QS Admin",
        "subtitle": "Welcome to the Quantum Shield management system",
        "greeting": "Hello, {name}!",
        "message": "Welcome to the Quantum Shield team. This onboarding will teach you about the QS ecosystem and the Core Principles (5 rules).",
        "roleBadge": "{from} → {to} permission upgrade preparation",
        "startButton": "Start Onboarding"
      },
      "overview": {
        "title": "Quantum Shield Overview",
        "subtitle": "Quantum-resistant asset protection protocol",
        "systems": {
          "consumer": {
            "title": "Consumer App",
            "description": "App for end users to Lock/Unlock assets. Achieves quantum resistance with Dilithium signatures."
          },
          "prover": {
            "title": "Prover Network",
            "description": "Distributed network that approves Unlocks with SPHINCS+ signatures. 127 nodes active."
          },
          "governance": {
            "title": "Governance",
            "description": "Decentralized decision-making by veQS holders. Parameter changes decided by voting."
          },
          "admin": {
            "title": "QS Admin",
            "description": "The management system you use. Handles monitoring, operations, and emergency response."
          }
        }
      },
      "principles": {
        "title": "Core Principles",
        "subtitle": "5 immutable rules (cannot be changed)",
        "items": {
          "cp1": {
            "title": "Full Quantum Resistance",
            "description": "Only NIST-compliant quantum-resistant algorithms. ECDSA, SHA-256 prohibited.",
            "tag": "CP-1"
          },
          "cp2": {
            "title": "Self-Custody",
            "description": "Users manage their own private keys. Storing private keys on servers is prohibited.",
            "tag": "CP-2"
          },
          "cp3": {
            "title": "Time Lock Requirement",
            "description": "Time Lock cannot be set to 0. Normal 24 hours, emergency 7 days lock period.",
            "tag": "CP-3"
          },
          "cp4": {
            "title": "Slashing Requirement",
            "description": "Slashing mechanism cannot be removed. Functions as a deterrent against misconduct.",
            "tag": "CP-4"
          },
          "cp5": {
            "title": "Transparency",
            "description": "Everything verifiable on-chain. Off-chain secret computation is prohibited.",
            "tag": "CP-5"
          }
        }
      },
      "emergency": {
        "title": "Emergency Procedures",
        "subtitle": "Emergency response procedures",
        "steps": {
          "step1": {
            "title": "When you detect an anomaly",
            "description": "Report to your supervisor (Matsumoto-san) first. Do not Pause on your own judgment."
          },
          "step2": {
            "title": "Record the situation",
            "description": "Record screenshots, logs, and timestamps. Post to Slack #incident channel."
          },
          "step3": {
            "title": "Pause decision (Admin or above)",
            "description": "Admin permission holder judges if Pause is necessary. Execute with 2+ Super Admins."
          },
          "step4": {
            "title": "Recovery work",
            "description": "Identify cause → Fix → Test → Security Council approval → Resume"
          },
          "step5": {
            "title": "Post-mortem",
            "description": "Create incident report and publish to community."
          }
        }
      },
