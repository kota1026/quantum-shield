# Quantum Shield Web Application - Environment Configuration
# Copy this file to .env.local and fill in your values

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL (default: localhost:8080)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Enable mock data fallback when backend is unavailable
NEXT_PUBLIC_ENABLE_MOCK=true

# =============================================================================
# WalletConnect / Reown Configuration
# =============================================================================

# WalletConnect Project ID (required for wallet connections)
# Get a project ID from https://cloud.walletconnect.com/
# For local development without wallet connectivity, use: placeholder-dev-id
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id-here

# =============================================================================
# Blockchain RPC URLs (optional)
# =============================================================================

# Sepolia testnet RPC (uses public RPC if not set)
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Mainnet RPC (uses public RPC if not set)
# NEXT_PUBLIC_MAINNET_RPC_URL=https://eth.llamarpc.com

# =============================================================================
# L3 Aegis Chain Configuration (optional)
# =============================================================================

# L3 RPC URL for local development
# NEXT_PUBLIC_L3_RPC_URL=http://localhost:8545
